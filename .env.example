HF_TOKEN=your_huggingface_token_here

# AWS credentials for S3 uploads.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional when using temporary STS credentials.
AWS_SESSION_TOKEN=your_aws_session_token
AWS_DEFAULT_REGION=us-east-1

# Model-Quantizer S3 output settings.
MQ_OUTPUT_S3_ENABLED=1
MQ_OUTPUT_S3_BUCKET=your-s3-bucket
MQ_OUTPUT_S3_PREFIX=model-quantizer/runai
# Optional for S3-compatible providers or custom endpoints.
MQ_OUTPUT_S3_REGION=us-east-1
MQ_OUTPUT_S3_ENDPOINT_URL=
